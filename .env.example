# --- 이 파일만 저장소에 커밋합니다. 실제 값은 .env.local / Vercel에만 넣으세요 ---
#
# Supabase → Project Settings → API
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon public 키 → NEXT_PUBLIC_SUPABASE_ANON_KEY (service_role 키는 넣지 마세요)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 브라우저에서 열리는 사이트 주소 (이메일 링크·OAuth 리다이렉트)
# 로컬: http://localhost:3000  (포트가 다르면 그에 맞게)
# Vercel: https://프로젝트이름.vercel.app 또는 커스텀 도메인

NEXT_PUBLIC_SITE_URL=http://localhost:3000
